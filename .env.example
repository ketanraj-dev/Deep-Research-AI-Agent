# ─────────────────────────────────────────────
#  Deep Research — Environment Variables
#  Copy this file to .env and fill in the values
#  $ cp .env.example .env
# ─────────────────────────────────────────────

# ── LLM Providers ───────────────────────────
# OpenAI  (used by the Search Agent — web browsing)
OPENAI_API_KEY=sk-...

# Google Gemini  (used by Planner, Writer, and Email agents)
GOOGLE_API_KEY=AIza...

# DeepSeek  (optional alternative provider)
DEEPSEEK_API_KEY=sk-...

# ── Email Delivery ───────────────────────────
# Set USE_EMAIL=true to send the report via SMTP.
# Set USE_EMAIL=false to send via Pushover push notification instead.
USE_EMAIL=true

# Gmail (or any SMTP provider)
EMAIL_ADDRESS=you@gmail.com
EMAIL_SMTP_SERVER=smtp.gmail.com
# Use a Gmail App Password — NOT your regular password.
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Pushover (optional) ─────────────────────
# Only needed when USE_EMAIL=false
PUSHOVER_USER=your_pushover_user_key
PUSHOVER_TOKEN=your_pushover_app_token

# ── Research Settings ────────────────────────
# How many parallel web searches the planner generates per query
HOW_MANY_SEARCHES=3
